{
    "configurations": [
        {
            "name": "Linux - Dedicated",
            "includePath": [
                "${workspaceFolder}/src/**",
                "${workspaceFolder}/vendor/cglm/include",
                "${workspaceFolder}/vendor/joltc/include",
                "${workspaceFolder}/vendor/stb",
				"${workspaceFolder}/vendor/enet/include"
            ],
            "defines": [
                "__USE_MISC",
				"__USE_POSIX",
				"__USE_GNU",
                "PLATFORM_LINUX",
                "ENGINE_DEDICATED"
            ],
            "compilerPath": "/usr/bin/clang",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-clang-x64",
            "configurationProvider": "go2sh.cmake-integration"
        },
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/src/**",
                "${workspaceFolder}/vendor/cglm/include",
                "${workspaceFolder}/vendor/joltc/include",
                "${workspaceFolder}/vendor/stb",
                "${workspaceFolder}/vendor/cimgui",
				"${workspaceFolder}/vendor/enet/include"
            ],
            "defines": [
                "__USE_MISC",
				"__USE_POSIX",
				"__USE_GNU",
                "PLATFORM_LINUX",
                "CIMGUI_USE_OPENGL3",
                "CIMGUI_USE_GLFW"
            ],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-clang-x64",
            "configurationProvider": "go2sh.cmake-integration"
        }
    ],
    "version": 4
}
